# Gemini — console.cloud.google.com → APIs → Generative Language API
GEMINI_API_KEY=your_gemini_api_key_here

# Kraken read-only key — kraken.com → Security → API → Add Key
# Permissions: Query Funds + Query Open Orders + Query Closed Orders + WebSockets
KRAKEN_API_KEY_READONLY=your_readonly_key_here
KRAKEN_API_SECRET_READONLY=your_readonly_secret_here

# Kraken trading key — adds Modify Orders + Cancel Orders. NEVER enable Withdraw Funds.
KRAKEN_API_KEY_TRADING=your_trading_key_here
KRAKEN_API_SECRET_TRADING=your_trading_secret_here

# Trading config
TRADING_MODE=paper
TRADING_PAIR=BTCUSD
MAX_POSITION_PCT=0.05
CONFIDENCE_THRESHOLD=0.75
STOP_LOSS_PCT=0.03
DAILY_LOSS_LIMIT_PCT=0.08
MAX_OPEN_POSITIONS=2
CONFLUENCE_MIN_SCORE=3

# Strategy — rule thresholds (tune these to optimise for your pair/timeframe)
RSI_OVERSOLD=28           # Rule 1: deep oversold BUY threshold
RSI_OVERBOUGHT=72         # Rule 2: overbought SELL threshold
RSI_SOFT_OVERSOLD=35      # Rule 7: ranging-market bounce BUY
RSI_SOFT_OVERBOUGHT=65    # Rule 8: ranging-market fade SELL
RSI_BULL_MIN=40           # Rule 5: bullish momentum RSI lower bound
RSI_BULL_MAX=65           # Rule 5: bullish momentum RSI upper bound
RSI_BEAR_MIN=35           # Rule 6: bearish momentum RSI lower bound
RSI_BEAR_MAX=60           # Rule 6: bearish momentum RSI upper bound
ATR_STOP_MULTIPLIER=1.5   # Stop distance = ATR × this
TP_RATIO=2.0              # Take-profit distance = stop_distance × this (2.0 = 2:1 R:R)
ADX_STRONG_THRESHOLD=35   # ADX above this → TRENDING_STRONG
ADX_WEAK_THRESHOLD=25     # ADX above this (below strong) → TRENDING_WEAK; below → RANGING
ATR_VOLATILE_ZSCORE=2.0   # ATR z-score above this → VOLATILE regime (stand aside)
MAX_HOLD_HOURS=48         # Max hours to hold a position before forced exit
RULE_CONF_EXTREME=0.82    # Confidence for Rules 1 & 2 (RSI extreme + BB + MACD cross)
RULE_CONF_CROSS=0.78      # Confidence for Rules 3 & 4 (EMA cross + regime)
RULE_CONF_STATE=0.72      # Confidence for Rules 5 & 6 (EMA momentum state)
RULE_CONF_RANGING=0.70    # Confidence for Rules 7 & 8 (RSI bounce/fade in ranging)

# Cycle intervals (minutes) — lower these for testing/validation
# Defaults: 15 / 60 / 240 (fast / standard / trend)
# For testing use: 1 / 5 / 15
FAST_LOOP_MINUTES=15
STANDARD_LOOP_MINUTES=60
TREND_LOOP_MINUTES=240

# API server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173
